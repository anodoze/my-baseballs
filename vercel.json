{
  "buildCommand": "npm run build",
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/team",
      "destination": "/team.html"
    },
    {
      "source": "/stats-leaders",
      "destination": "/stats-leaders.html"
    },
    {
      "source": "/sickos",
      "destination": "/sickos.html"
    }
  ]
}